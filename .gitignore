# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/backups/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.production.example
!.env.test.local.example

# playwright
/playwright/.auth/
/playwright-report/
/test-results/
/blob-report/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/courses/
.mcp.json

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Design scratch (AI-generated icon candidates, etc.)
/scratch/
