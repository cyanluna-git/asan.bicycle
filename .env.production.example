# ============================================================
# Vercel Environment Variables
# Copy these to your Vercel project dashboard:
#   Settings → Environment Variables
# ============================================================

# Supabase — project URL and public anon key
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Kakao Map — JavaScript App Key
# Get from: https://developers.kakao.com/console/app → 앱 키 → JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-javascript-key
