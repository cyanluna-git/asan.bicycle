# Test environment secrets
# Copy to .env.test.local and fill in the values.
# .env.test.local is gitignored — never commit real credentials.
#
# The Supabase project must have email/password auth enabled and a
# pre-seeded test user matching TEST_USER_EMAIL / TEST_USER_PASSWORD.
# Provisioning the test account is out of scope for the test infra task.

# -----------------------------------------------------------------------------
# Supabase (API integration + E2E)
# -----------------------------------------------------------------------------
# These are consumed directly by the app and by vitest integration tests.
# In CI (.github/workflows/test.yml) they are populated from the following
# GitHub Actions secrets:
#   SUPABASE_TEST_URL               -> NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_TEST_ANON_KEY          -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_TEST_SERVICE_ROLE_KEY  -> SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Playwright E2E
# -----------------------------------------------------------------------------
# Mapped from GitHub secrets of the same name in CI.
TEST_USER_EMAIL=e2e-tester@example.com
TEST_USER_PASSWORD=changeme

# Course ID used by course-detail E2E specs. Must exist in the test DB.
TEST_DETAIL_COURSE_ID=00000000-0000-0000-0000-000000000000

# Optional: override the dev server URL Playwright targets.
# Defaults to http://localhost:3102 (the project's `pnpm dev` port).
# BASE_URL=http://localhost:3102
