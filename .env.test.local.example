# Playwright E2E test environment
# Copy to .env.test.local and fill in the values.
# .env.test.local is gitignored — never commit real credentials.
#
# The Supabase project must have email/password auth enabled and a
# pre-seeded test user matching TEST_USER_EMAIL / TEST_USER_PASSWORD.
# Provisioning the test account is out of scope for the test infra task.

TEST_USER_EMAIL=e2e-tester@example.com
TEST_USER_PASSWORD=changeme

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: override the dev server URL Playwright targets.
# Defaults to http://localhost:3102 (the project's `pnpm dev` port).
# BASE_URL=http://localhost:3102
